# Environment variables for Viagen
# Copy this file to .env and fill in values

# ─── Claude Auth (pick one) ──────────────────────────────────────
# ANTHROPIC_API_KEY=

# Or use Claude Max/Pro OAuth (from `npx viagen setup`)
# CLAUDE_ACCESS_TOKEN=
# CLAUDE_REFRESH_TOKEN=
# CLAUDE_TOKEN_EXPIRES=

# ─── Plugin Options ──────────────────────────────────────────────
# Override the Claude model (e.g. sonnet, opus, haiku)
# VIAGEN_MODEL=

# Enable verbose debug logging (also settable via plugin option)
# VIAGEN_DEBUG=1

# ─── GitHub ──────────────────────────────────────────────────────
# GitHub PAT for git-based sandbox (enables commit+push from sandbox)
# GITHUB_TOKEN=

# Git repo info for sandbox (written by `viagen setup`, or set manually)
# These override runtime git detection so sandboxes clone the correct repo.
# GIT_REMOTE_URL=
# GIT_BRANCH=
# GIT_USER_NAME=
# GIT_USER_EMAIL=

# ─── Vercel ──────────────────────────────────────────────────────
# Vercel Sandbox (run `vercel link && vercel env pull` or set manually)
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=

# ─── Platform ──────────────────────────────────────────────────
# Platform environment ID (written by `viagen sync`)
# VIAGEN_ENVIRONMENT_ID=

# Platform project ID (task container, set automatically in sandbox)
# VIAGEN_PROJECT_ID=

# Custom platform URL (default: https://app.viagen.dev)
# VIAGEN_PLATFORM_URL=

# User API token (from `viagen login`). Enables platform features locally
# without a sandbox. When set, used instead of VIAGEN_AUTH_TOKEN.
# VIAGEN_USER_TOKEN=

# ─── Sandbox-internal (auto-set by platform, do not edit! these are just for reference when building viagen) ───────
# VIAGEN_AUTH_TOKEN=        # Bearer token for sandbox auth
# VIAGEN_AUTH_EMAIL=        # User email in sandbox session
# VIAGEN_CALLBACK_URL=     # Platform callback endpoint
# VIAGEN_TASK_ID=           # Task being worked on
# VIAGEN_TASK_TYPE=         # Task type: task or plan
# VIAGEN_BRANCH=            # Branch name inside sandbox (set by the platform)
# VIAGEN_PROMPT=            # Auto-sent prompt in headless mode
# VIAGEN_SESSION_START=     # Session start timestamp (unix)
# VIAGEN_SESSION_TIMEOUT=   # Session timeout in seconds

{"role":"assistant","type":"tool_use","name":"Write","input":{"file_path":"/vercel/sandbox/app/lib/zip.server.ts","content":"import JSZip from \"jszip\";\nimport { db } from \"../../db/client\";\nimport {\n  documents,\n  personnel,\n  training,\n  classes,\n  instructors,\n  companies,\n} from \"../../db/schema\";\nimport { eq, and, isNotNull, ne } from \"drizzle-orm\";\nimport {\n  downloadFile,\n  generatePersonnelPhotoPath,\n  generateGcsUrl,\n} from \"./gcs.server\";\nimport type { User } from \"./auth.server\";\nimport { canAccessPersonnelAsync } from \"./roles.server\";\n\ninterface PersonnelFile {\n  buffer: Buffer;\n  filename: string;\n  folder: string;\n}\n\n/**\n * Create a ZIP file containing all documents, certificates, and photos for a personnel record\n * @param personnelId - The personnel ID to create zip for\n * @param user - The authenticated user\n * @param isImpersonating - Whether the user is impersonating another user\n * @returns Promise<Buffer> - The ZIP file buffer\n */\nexport async function createPersonnelZip(\n  personnelId: string,\n  user: User,\n  isImpersonating: boolean\n): Promise<Buffer> {\n  // Get personnel record for access control and naming\n  const [person] = await db\n    .select({\n      id: personnel.id,\n      firstName: personnel.firstName,\n      lastName: personnel.lastName,\n      companyId: personnel.companyId,\n      photo: personnel.photo,\n    })\n    .from(personnel)\n    .where(eq(personnel.id, personnelId))\n    .limit(1);\n\n  if (!person) {\n    throw new Error(\"Personnel not found\");\n  }\n\n  // Check access using existing authorization logic\n  const hasAccess = await canAccessPersonnelAsync(\n    user,\n    person,\n    personnelId,\n    isImpersonating\n  );\n\n  if (!hasAccess) {\n    throw new Error(\"Unauthorized access to personnel documents\");\n  }\n\n  // Collect all files to include in ZIP\n  const filesToZip: PersonnelFile[] = [];\n  const errors: string[] = [];\n\n  // 1. Get uploaded documents\n  try {\n    const personnelDocuments = await db\n      .select({\n        id: documents.id,\n        fileName: documents.fileName,\n        fileUrl: documents.fileUrl,\n      })\n      .from(documents)\n      .where(eq(documents.personnelId, personnelId));\n\n    // Download all documents concurrently\n    const documentDownloads = await Promise.allSettled(\n      personnelDocuments.map(async (doc) => {\n        if (!doc.fileUrl) return null;\n        const { buffer } = await downloadFile(doc.fileUrl);\n        return {\n          buffer,\n          filename: doc.fileName,\n          folder: \"Documents\",\n        };\n      })\n    );\n\n    documentDownloads.forEach((result, index) => {\n      if (result.status === \"fulfilled\" && result.value) {\n        filesToZip.push(result.value);\n      } else {\n        errors.push(\n          `Failed to download document: ${personnelDocuments[index].fileName}`\n        );\n      }\n    });\n  } catch (error) {\n    errors.push(\"Failed to retrieve personnel documents\");\n  }\n\n  // 2. Get personnel photo\n  try {\n    if (person.photo) {\n      const { buffer } = await downloadFile(person.photo);\n      filesToZip.push({\n        buffer,\n        filename: \"personnel_photo.jpg\",\n        folder: \"Photos\",\n      });\n    }\n  } catch (error) {\n    errors.push(\"Failed to download personnel photo\");\n  }\n\n  // 3. Get training certificates (paid only, following existing pattern)\n  try {\n    const paidTrainingRecords = await db\n      .select({\n        trainingId: training.id,\n        courseName: training.courseName,\n        completedOn: training.completedOn,\n        result: training.result,\n        personnelFirstName: personnel.firstName,\n        personnelLastName: personnel.lastName,\n        companyName: companies.name,\n        leadInstructorFirstName: instructors.firstName,\n        leadInstructorLastName: instructors.lastName,\n      })\n      .from(training)\n      .innerJoin(personnel, eq(training.personnelId, personnel.id))\n      .leftJoin(companies, eq(training.companyId, companies.id))\n      .leftJoin(classes, eq(training.classId, classes.id))\n      .leftJoin(instructors, eq(classes.leadInstructorId, instructors.id))\n      .where(\n        and(\n          eq(training.personnelId, personnelId),\n          isNotNull(training.paidOn), // Only paid certificates\n          isNotNull(training.result),\n          ne(training.result, \"\"),\n          ne(training.result, \"Fail\")\n        )\n      );\n\n    // For now, add certificate placeholders (actual PDF generation would require additional implementation)\n    // This follows the pattern from existing certificate routes but generates text summaries instead of full PDFs\n    paidTrainingRecords.forEach((record) => {\n      const certificateContent = `CERTIFICATE OF COMPLETION\n\nPersonnel: ${record.personnelFirstName} ${record.personnelLastName}\nCompany: ${record.companyName || \"Unknown\"}\nCourse: ${record.courseName || \"Unknown Course\"}\nCompleted: ${record.completedOn ? record.completedOn.toLocaleDateString() : \"Unknown Date\"}\nResult: ${record.result}\nInstructor: ${record.leadInstructorFirstName} ${record.leadInstructorLastName || \"Unknown\"}\n\nThis is a summary of the training completion. For official certificates, please access the certificate printing system.\n`;\n\n      const certificateBuffer = Buffer.from(certificateContent, \"utf-8\");\n      const safeCourseName = (record.courseName || \"Unknown_Course\")\n        .replace(/[^a-zA-Z0-9]/g, \"_\")\n        .substring(0, 50);\n\n      filesToZip.push({\n        buffer: certificateBuffer,\n        filename: `${safeCourseName}_certificate.txt`,\n        folder: \"Certificates\",\n      });\n    });\n  } catch (error) {\n    errors.push(\"Failed to retrieve training certificates\");\n  }\n\n  // Create ZIP file\n  const zip = new JSZip();\n\n  // Create folder structure and add files\n  filesToZip.forEach((file) => {\n    const folder = zip.folder(file.folder);\n    if (folder) {\n      folder.file(file.filename, file.buffer);\n    }\n  });\n\n  // Add error log if there were any issues\n  if (errors.length > 0) {\n    const errorLog = `DOWNLOAD ERRORS\n\nThe following errors occurred while creating this ZIP file:\n\n${errors.join(\"\\n\")}\n\nThis does not affect the files that were successfully included.\nGenerated: ${new Date().toISOString()}\n`;\n    zip.file(\"_download_errors.txt\", errorLog);\n  }\n\n  // Generate ZIP buffer\n  const zipBuffer = await zip.generateAsync({\n    type: \"nodebuffer\",\n    compression: \"DEFLATE\",\n    compressionOptions: {\n      level: 6, // Balance between compression and speed\n    },\n  });\n\n  return zipBuffer;\n}\n\n/**\n * Generate a safe filename for the ZIP download\n * @param firstName - Personnel first name\n * @param lastName - Personnel last name\n * @param personnelId - Personnel ID\n * @returns string - Safe filename for download\n */\nexport function generateZipFilename(\n  firstName: string,\n  lastName: string,\n  personnelId: string\n): string {\n  const safeName = `${firstName}_${lastName}_${personnelId}`\n    .replace(/[^a-zA-Z0-9_]/g, \"_\")\n    .replace(/_{2,}/g, \"_\")\n    .substring(0, 100); // Limit length\n\n  return `${safeName}_documents.zip`;\n}"},"timestamp":1772733380272}

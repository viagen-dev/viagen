{"role":"assistant","type":"tool_use","name":"Write","input":{"file_path":"/vercel/sandbox/app/routes/api.personnel.zip-download.tsx","content":"import { db } from \"../../db/client\";\nimport { personnel } from \"../../db/schema\";\nimport { eq } from \"drizzle-orm\";\nimport { requireUser } from \"../lib/auth.server\";\nimport { canAccessPersonnelAsync } from \"../lib/roles.server\";\nimport { createPersonnelZip, generateZipFilename } from \"../lib/zip.server\";\nimport type { Route } from \"./+types/api.personnel.zip-download\";\n\n// GET - Create and stream ZIP file containing all personnel documents and certificates\nexport async function loader({ request }: Route.LoaderArgs) {\n  const { user, isImpersonating } = await requireUser(request);\n\n  const url = new URL(request.url);\n  const personnelId = url.searchParams.get(\"id\");\n\n  if (!personnelId) {\n    return new Response(\"Missing personnel ID\", { status: 400 });\n  }\n\n  // Fetch personnel record for access control and filename generation\n  const [person] = await db\n    .select({\n      id: personnel.id,\n      firstName: personnel.firstName,\n      lastName: personnel.lastName,\n      companyId: personnel.companyId,\n    })\n    .from(personnel)\n    .where(eq(personnel.id, personnelId))\n    .limit(1);\n\n  if (!person) {\n    return new Response(\"Personnel not found\", { status: 404 });\n  }\n\n  // Check access using existing authorization logic\n  // This ensures only authorized users can download personnel documents\n  const hasAccess = await canAccessPersonnelAsync(\n    user,\n    person,\n    personnelId,\n    isImpersonating\n  );\n\n  if (!hasAccess) {\n    return new Response(\"Unauthorized\", { status: 403 });\n  }\n\n  try {\n    // Create ZIP file with all personnel documents, certificates, and photos\n    const zipBuffer = await createPersonnelZip(\n      personnelId,\n      user,\n      isImpersonating\n    );\n\n    // Generate safe filename\n    const filename = generateZipFilename(\n      person.firstName || \"Unknown\",\n      person.lastName || \"Unknown\",\n      personnelId\n    );\n\n    // Return ZIP file as download\n    // Following the pattern from existing export endpoints\n    return new Response(zipBuffer, {\n      headers: {\n        \"Content-Type\": \"application/zip\",\n        \"Content-Disposition\": `attachment; filename=\"${filename}\"`,\n        \"Content-Length\": zipBuffer.length.toString(),\n      },\n    });\n  } catch (error) {\n    console.error(\"Error creating personnel ZIP:\", error);\n\n    if (error instanceof Error && error.message === \"Unauthorized access to personnel documents\") {\n      return new Response(\"Unauthorized\", { status: 403 });\n    }\n\n    if (error instanceof Error && error.message === \"Personnel not found\") {\n      return new Response(\"Personnel not found\", { status: 404 });\n    }\n\n    return new Response(\"Internal server error creating ZIP file\", { status: 500 });\n  }\n}"},"timestamp":1772733396995}
